---
import { Image } from 'astro:assets';
import backgroundImage from '../../public/placeholder.png';

interface Props {
    title?: string;
    description?: string;
    date?: Date;
    price?: number;
    poster?: string; // Optional poster image URL
    location?: {
        lat: number;
        lon: number;
    };
    currentSeason?: string;
}

const { 
    title, 
    description, 
    date, 
    price, 
    location, 
    poster,
    currentSeason
} = Astro.props;

const hasConcert = Boolean(title && description && date && (price ?? 0) >= 0);

// Format date if available
let formattedDate = '';
if (date) {
    const dateFormatter = new Intl.DateTimeFormat('fr-FR', {
        weekday: 'long',
        day: 'numeric',
        month: 'long',
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit',
        timeZone: 'Europe/Paris'
    });
    formattedDate = dateFormatter.format(date);
}

---

<div class="relative h-full rounded-3xl overflow-hidden group-hover:shadow-2xl transition-all duration-500 border border-gray-100 flex flex-col min-h-[400px] md:min-h-[500px]">
    <!-- Background poster image with overlay -->
    <div class="absolute inset-0 z-0 bg-gray-900">
        {poster == null ? (
            <div class="w-full h-full bg-gradient-to-br from-pumpkin-100 to-pumpkin-50"></div>
        ) : (
            <Image src={poster} inferSize={true} alt="Concert poster" class="w-full h-full object-cover opacity-90 group-hover:scale-105 transition-transform duration-1000 ease-out" />
        )}
    </div>
    
    <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-transparent to-transparent pointer-events-none z-10"></div>
    
    <!-- Content (with relative positioning to appear above the background) -->
    <div class="relative z-20 flex flex-col h-full justify-between p-6 md:p-10">
        <div class="flex items-center justify-between mb-4">
            {hasConcert && date && (
                <span class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider bg-pumpkin-500 text-white">
                    {new Date() > date ? "Passé" : "À venir"}
                </span>
            )}
        </div>
        
        {hasConcert ? (
            <div class="mt-auto md:w-3/4 lg:w-2/3 bg-white/95 backdrop-blur-xl p-6 md:p-8 rounded-2xl shadow-2xl border border-white/50 transform group-hover:-translate-y-2 transition-transform duration-500">
                <h3 class="text-3xl font-bold text-gray-900 mb-4 tracking-tight">{title}</h3>
                
                <div class="flex flex-wrap gap-3 mb-6 text-sm md:text-base text-gray-700 font-medium">
                    <div class="flex items-center gap-2 bg-gray-100/80 px-3 py-1.5 rounded-lg">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-pumpkin-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        <span>{formattedDate}</span>
                    </div>
                    
                    {location && (
                        <div class="flex items-center gap-2 bg-gray-100/80 px-3 py-1.5 rounded-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-pumpkin-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                            <span>Paris, France</span>
                        </div>
                    )}
                    
                    <div class="flex items-center gap-2 bg-gray-100/80 px-3 py-1.5 rounded-lg">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-pumpkin-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
                        </svg>
                        <span>{price ?? 0 === 0 ? 'Entrée libre' : `${price}€`}</span>
                    </div>
                </div>
                
                <div class="flex flex-wrap gap-3">
                    <a href={`/concert/${title.toLowerCase().replace(/\s+/g, '-')}`} class="inline-flex justify-center items-center bg-gray-900 text-white font-semibold py-2.5 px-5 rounded-xl hover:bg-gray-800 transition-colors shadow-lg">
                        En savoir plus
                    </a>
                    <a href="#" class="inline-flex justify-center items-center bg-pumpkin-500 text-white font-semibold py-2.5 px-5 rounded-xl hover:bg-pumpkin-600 transition-colors shadow-lg shadow-pumpkin-500/30">
                        Réserver
                    </a>
                </div>
            </div>
        ) : (
            <div class="mt-auto w-full md:w-3/4 lg:w-2/3 bg-white/95 backdrop-blur-xl rounded-2xl shadow-2xl border border-white/50 p-8 transform group-hover:-translate-y-2 transition-transform duration-500"> 
                <h3 class="text-2xl font-bold text-gray-900 mb-3">Programmation à venir</h3>
                <p class="text-gray-600 mb-6">Notre programmation pour la prochaine saison sera disponible bientôt. Restez à l'écoute !</p>
                <a href={`saison/${currentSeason}`} class="inline-block bg-pumpkin-500 text-white font-bold py-3 px-6 rounded-xl hover:bg-pumpkin-600 shadow-md hover:shadow-lg transition-all">
                    Voir notre saison actuelle
                </a>
            </div>
        )}
    </div>
</div>