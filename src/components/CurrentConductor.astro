---
import {type Chef} from "../lib/contentful";
interface Props {
    name: string
    resume: string
    portrait: string | undefined
}

const {name, resume, portrait} = Astro.props
---

<div class="group relative bg-white p-8 md:p-10 rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 border border-gray-100 flex flex-col h-full">
    <div class="absolute -right-12 -top-12 w-40 h-40 bg-pumpkin-50 rounded-full opacity-50 group-hover:scale-150 transition-transform duration-700 pointer-events-none"></div>
    <div class="relative z-10 flex flex-col h-full">
        <h2 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-6 border-b border-gray-100 pb-4">Direction Musicale</h2>
        
        <div class="flex items-center gap-6 mb-6">
            {portrait && (
                <div class="flex-shrink-0">
                    <img 
                        src={portrait} 
                        alt={`${name} - Direction musicale`} 
                        class="w-24 h-24 md:w-28 md:h-28 rounded-full object-cover shadow-md group-hover:scale-105 transition-transform duration-500 ring-4 ring-pumpkin-50/50 border border-gray-100"
                    />
                </div>
            )}
            <div>
                <h3 class="text-2xl font-bold text-gray-900 leading-tight mb-1">{name}</h3>
                <span class="text-pumpkin-600 font-medium text-sm">Chef Principal</span>
            </div>
        </div>
        
        <div class="prose prose-sm text-gray-600 line-clamp-4 leading-relaxed mb-6" set:html={resume}></div>
        
        <div class="mt-auto pt-2 flex justify-end relative z-20">
            <a href={"/direction/current"} class="inline-flex items-center text-pumpkin-500 font-bold hover:text-pumpkin-600 group/link">
                Découvrir son parcours
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 transform group-hover/link:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
            </a>
        </div>
    </div>
</div>