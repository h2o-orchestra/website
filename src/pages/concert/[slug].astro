---
import {type Concert, contentfulClient, concerts} from "../../lib/contentful";
import { documentToHtmlString } from "@contentful/rich-text-html-renderer";
import Layout from "../../layouts/Layout.astro";
import { getSeason } from "../../lib/seasons";
import { truncateDescription } from "../../lib/string";

export async function getStaticPaths() {
    const entries = await contentfulClient.getEntries<Concert>({
        content_type: "concert",
    });

    return Promise.all(entries.items.map(async (item) => {
        let posterUrl: string = "/placeholder.png";
        if (item.fields.poster?.sys?.id) {
            const asset = await contentfulClient.getAsset(item.fields.poster.sys.id);
            const url = asset.fields.file?.url;
            if (url) posterUrl = url.startsWith('//') ? `https:${url}` : url;
        }

        return (
            {
                params: {slug: item.fields.title.toLowerCase().replace(/\s+/g, '-')},
                props: {
                    title: item.fields.title,
                    date: item.fields.date,
                    description: documentToHtmlString(item.fields.description),
                    price: item.fields.price,
                    location: item.fields.location,
                    address: item.fields.address,
                    poster: posterUrl,
                },
            })
    }));
}

const {title, date, description, price, location, address, poster} = Astro.props;

// Format date
const dateFormatter = new Intl.DateTimeFormat('fr-FR', {
    weekday: 'long',
    day: 'numeric',
    month: 'long',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
});

const formattedDate = dateFormatter.format(new Date(date));
const isPastConcert = new Date(date) < new Date();
// Generate ICS calendar file data
const generateIcsData = () => {
    const eventDate = new Date(date);
    const endDate = new Date(eventDate);
    endDate.setHours(endDate.getHours() + 2); // Assuming 2-hour concert duration
    
    const formatIcsDate = (date) => {
        return date.toISOString().replace(/-|:|\.\d+/g, '').slice(0, -1);
    };
    
    return `BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//Orchestre H2O//Concert Calendar//FR
CALSCALE:GREGORIAN
BEGIN:VEVENT
SUMMARY:${title} - Orchestre H2O
DTSTART:${formatIcsDate(eventDate)}
DTEND:${formatIcsDate(endDate)}
LOCATION:${location ? 'Paris, France' : 'À confirmer'}
DESCRIPTION:${title.replace(/,/g, '\\,')}
STATUS:CONFIRMED
SEQUENCE:0
END:VEVENT
END:VCALENDAR`;
};

// Convert ICS data to a downloadable data URL
const calendarUrl = `data:text/calendar;charset=utf-8,${encodeURIComponent(generateIcsData())}`;

const concertsBySeason = concerts.filter((item) => getSeason(new Date(item.date)) === getSeason(new Date(date))).slice(0, 3);

const otherConcerts = concertsBySeason.filter(c => c.title !== title)
---

<Layout title={title} activeNav="saisons">
    <!-- Hero section with Dark Theme -->
    <div class="relative py-24 md:py-32 xl:py-40 overflow-hidden bg-gray-900">
        <!-- Poster background with rich gradient overlay -->
        <div class="absolute inset-0 z-0">
            {poster ? (
                <img src={poster} alt={`Affiche du concert ${title}`} class="w-full h-full object-cover filter blur-[2px] scale-105" />
            ) : (
                <div class="w-full h-full bg-gray-900"></div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/80 to-gray-900/40"></div>
            <div class="absolute inset-0 bg-gradient-to-r from-pumpkin-900/30 to-transparent"></div>
        </div>
        
        <div class="container mx-auto px-4 relative z-10">
            <div class="max-w-4xl mx-auto text-center">
                <div class="mb-6 flex justify-center gap-3">
                    {isPastConcert ? (
                        <span class="inline-block px-4 py-1.5 bg-gray-800 border border-gray-700 text-gray-300 text-sm font-bold uppercase tracking-widest rounded-full">
                            Concert passé
                        </span>
                    ) : (
                        <span class="inline-block px-4 py-1.5 bg-pumpkin-500 text-white text-sm font-bold uppercase tracking-widest shadow-lg rounded-full">
                            À venir
                        </span>
                    )}
                    <span class="inline-block px-4 py-1.5 bg-white/10 backdrop-blur-md border border-white/20 text-white text-sm font-bold uppercase tracking-widest rounded-full">
                        {getSeason(new Date(date))}
                    </span>
                </div>
                
                <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white mb-8 tracking-tight drop-shadow-lg">{title}</h1>
                
                <div class="flex flex-wrap items-center justify-center text-blue-100 mb-10 gap-x-8 gap-y-4">
                    <div class="flex items-center text-xl font-light">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-3 text-pumpkin-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        <time>{formattedDate.charAt(0).toUpperCase() + formattedDate.slice(1)}</time>
                    </div>
                </div>
                
                {!isPastConcert && (
                    <div class="flex flex-wrap justify-center gap-4">
                        {price && (
                            <a href="#tickets" class="inline-flex items-center bg-pumpkin-500 text-white font-bold tracking-wide uppercase text-sm py-4 px-8 rounded-full shadow-xl shadow-pumpkin-500/20 hover:bg-pumpkin-600 transition-all hover:-translate-y-1">
                                Réserver des places
                            </a>
                        )}
                        <a href={calendarUrl} download={`concert-h2o-${title.toLowerCase().replace(/\s+/g, '-')}.ics`} class="inline-flex items-center bg-white/10 backdrop-blur-md text-white border border-white/30 font-bold tracking-wide uppercase text-sm py-4 px-8 rounded-full hover:bg-white/20 transition-all hover:-translate-y-1">
                            Ajouter au calendrier
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
                            </svg>
                        </a>
                    </div>
                )}
            </div>
        </div>
    </div>
    
    <!-- Main content shifted up -->
    <div class="container mx-auto px-4 relative z-20 -mt-12 pb-20 max-w-7xl">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Main concert description in Bento Box -->
            <div class="lg:col-span-2">
                <div class="bg-white rounded-[2rem] p-8 md:p-12 shadow-2xl border border-gray-100">
                    <h2 class="text-3xl font-bold text-gray-900 mb-8 tracking-tight">Programme</h2>
                    <div class="prose prose-lg md:prose-xl max-w-none text-gray-600 font-light leading-relaxed prose-h3:text-gray-900 prose-h3:font-bold prose-h3:text-2xl mt-4">
                        <div set:html={description} />
                    </div>
                </div>
            </div>
            
            <!-- Sidebar with event details -->
            <div class="lg:col-span-1 space-y-8">
                <!-- Info Box -->
                <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-gray-100 relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-h2o-blue/10 rounded-full blur-2xl -mr-10 -mt-10 pointer-events-none"></div>
                    <h2 class="text-2xl font-bold text-gray-900 mb-8 relative z-10 tracking-tight">Détails du concert</h2>
                    
                    <div class="space-y-6 relative z-10">
                        <div class="flex items-start gap-4">
                            <div class="bg-blue-50 p-3 rounded-2xl flex-shrink-0 text-h2o-blue shadow-inner">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                            </div>
                            <div>
                                <div class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Date</div>
                                <div class="text-gray-900 font-medium text-lg leading-snug">{formattedDate.charAt(0).toUpperCase() + formattedDate.slice(1)}</div>
                            </div>
                        </div>
                        
                        <div class="flex items-start gap-4">
                            <div class="bg-blue-50 p-3 rounded-2xl flex-shrink-0 text-h2o-blue shadow-inner">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                            </div>
                            <div>
                                <div class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Lieu</div>
                                <div class="text-gray-900 font-medium text-lg leading-snug">{address}</div>
                            </div>
                        </div>
                        
                        <div class="flex items-start gap-4">
                            <div class="bg-blue-50 p-3 rounded-2xl flex-shrink-0 text-h2o-blue shadow-inner">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
                                </svg>
                            </div>
                            <div>
                                <div class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Tarif</div>
                                {price ? <div class="text-gray-900 font-medium text-lg">{price}€</div> : <div class="text-gray-900 font-medium text-lg">Entrée libre</div>}
                            </div>
                        </div>
                    </div>
                </div>
                
                {!isPastConcert && price && (
                    <div id="tickets" class="bg-gray-900 p-8 rounded-[2rem] shadow-xl border border-gray-800 text-white relative overflow-hidden">
                        <div class="absolute bottom-0 right-0 w-32 h-32 bg-pumpkin-500/20 rounded-full blur-2xl -mr-10 -mb-10 pointer-events-none"></div>
                        <h2 class="text-2xl font-bold mb-6 tracking-tight relative z-10">Réservation</h2>
                        
                        <div class="space-y-4 mb-8 relative z-10">
                            <div class="flex justify-between items-center border-b border-gray-800 pb-3">
                                <span class="text-gray-400 font-light">Tarif plein</span>
                                <span class="font-bold text-xl">{price}€</span>
                            </div>
                            <div class="flex justify-between items-center border-b border-gray-800 pb-3">
                                <span class="text-gray-400 font-light">Tarif réduit</span>
                                <span class="font-bold text-xl">{Math.floor(price * 0.8)}€</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="text-gray-400 font-light">Étudiants</span>
                                <span class="font-bold text-xl">{Math.floor(price * 0.5)}€</span>
                            </div>
                        </div>
                        
                        <a href="#" class="block w-full bg-pumpkin-500 text-white text-center font-bold tracking-wide uppercase text-sm py-4 rounded-xl shadow-lg shadow-pumpkin-500/20 hover:bg-pumpkin-600 transition-all hover:-translate-y-1 relative z-10">
                            Acheter des billets
                        </a>
                    </div>
                )}
                
                {location && (
                    <div class="bg-white p-2 rounded-[2rem] shadow-xl border border-gray-100 overflow-hidden">
                        <div class="rounded-[1.5rem] overflow-hidden">
                            <img src={`https://maps.geoapify.com/v1/staticmap?style=osm-bright-smooth&width=600&height=400&center=lonlat%3A${location.lon}%2C${location.lat}&marker=lonlat:${location.lon},${location.lat};color:%23ff0000&zoom=16&apiKey=9f6d039317ef41f485a9dad143e95d4b`} 
                                alt="Carte du lieu du concert" 
                                class="w-full h-auto filter opacity-[0.9] grayscale-[0.2] transition-all hover:grayscale-0"
                            />
                        </div>
                    </div>
                )}
            </div>
        </div>
    </div>
    
    <!-- Related concerts using the standard bento display -->
    <section class="bg-gray-50 py-24 border-t border-gray-100">
        <div class="container mx-auto px-4 max-w-7xl">
            <div class="flex items-center justify-between mb-12">
                <h2 class="text-3xl font-extrabold text-gray-900 tracking-tight">Dans la même saison</h2>
                <a href={`/saison/${getSeason(new Date(date))}`} class="text-h2o-blue font-bold text-sm tracking-wide uppercase hover:text-blue-800 transition-colors flex items-center hidden md:flex">
                    Voir la saison
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </a>
            </div>
            
            {otherConcerts.length > 0 ? (
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
                    {otherConcerts.map((concert) => (
                        <a 
                            href={`/concert/${encodeURI(concert.title.toLowerCase().replace(/\s+/g, '-'))}`}
                            class="group relative bg-white rounded-[2rem] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2 border border-gray-100 flex flex-col h-[500px]"
                        >
                            <div class="absolute inset-0 z-0 bg-gray-900">
                                {concert.poster ? (
                                    <img 
                                        src={concert.poster}
                                        alt={concert.title}
                                        class="w-full h-full object-cover opacity-[0.85] transition-transform duration-1000 group-hover:scale-105"
                                    />
                                ) : (
                                    <div class="w-full h-full bg-gradient-to-br from-gray-800 to-gray-900"></div>
                                )}
                            </div>
                            
                            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/90 via-gray-900/40 to-transparent z-10 pointer-events-none"></div>
                            
                            <div class="relative z-20 p-8 flex flex-col h-full justify-end">
                                <div class="mb-auto flex justify-between items-start w-full">
                                    <span class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-bold bg-white/90 backdrop-blur-md text-gray-900 shadow-sm">
                                        {new Date(concert.date).toLocaleDateString("fr-FR", {day: 'numeric', month: 'long', year: 'numeric'})}
                                    </span>
                                </div>
                                
                                <div class="bg-white/10 backdrop-blur-md p-6 rounded-2xl border border-white/20 transform group-hover:-translate-y-1 transition-transform duration-500">
                                    <h2 class="text-2xl font-bold text-white mb-3 drop-shadow-sm line-clamp-2">
                                        {concert.title}
                                    </h2>
                                    
                                    {concert.description && (
                                        <div class="text-gray-300 line-clamp-2 font-light text-sm mb-4" set:html={truncateDescription(concert.description)}>
                                        </div>
                                    )}
                                    
                                    <span class="inline-flex items-center text-pumpkin-400 font-bold group-hover:text-pumpkin-300 transition-colors text-sm uppercase tracking-wide">
                                        Explorer
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                        </svg>
                                    </span>
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            ) : (
                <div class="bg-white rounded-[2rem] p-12 shadow-sm border border-gray-100 text-center max-w-2xl mx-auto">
                    <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-4 tracking-tight">Aucun autre concert</h3>
                    <p class="text-gray-600 font-light text-lg mb-8">Cet événement est le seul programmé pour sa saison.</p>
                    <a href="/saison" class="inline-flex items-center justify-center px-8 py-3 font-bold rounded-full text-white bg-gray-900 hover:bg-pumpkin-500 transition-colors shadow-lg">
                        Voir toutes les saisons
                    </a>
                </div>
            )}
            
            <div class="mt-8 text-center md:hidden">
                <a href={`/saison/${getSeason(new Date(date))}`} class="inline-flex text-gray-600 font-bold text-sm tracking-wide uppercase hover:text-h2o-blue transition-colors items-center">
                    Voir la saison
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </a>
            </div>
        </div>
    </section>
</Layout>