---
import Layout from '../layouts/Layout.astro';
import { allRecrutements } from '../lib/contentful';

---

<Layout title="Recrutement" activeNav="recrutement">
    <!-- Hero section with Dark Theme -->
    <div class="relative bg-gray-900 py-24 lg:py-32 overflow-hidden">
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-gradient-to-tr from-pumpkin-900/40 via-gray-900 to-gray-900 z-10"></div>
            <div class="absolute top-0 right-0 w-[50%] h-[50%] rounded-full bg-h2o-blue/20 blur-[130px]"></div>
            <div class="absolute bottom-0 left-0 w-[40%] h-[40%] rounded-full bg-pumpkin-600/20 blur-[130px]"></div>
        </div>
        <div class="container mx-auto px-4 relative z-20 text-center">
            <div class="max-w-4xl mx-auto">
                <h1 class="text-5xl md:text-6xl font-extrabold text-white mb-6 tracking-tight drop-shadow-sm">Rejoignez l'Orchestre H₂O</h1>
                <p class="text-xl md:text-2xl text-gray-300 font-light max-w-2xl mx-auto leading-relaxed">
                    Partagez notre passion pour la musique d'harmonie et intégrez une formation musicale dynamique et ambitieuse.
                </p>
            </div>
        </div>
    </div>
    
    <!-- Main content container shifted up to overlap hero slightly -->
    <div class="relative -mt-8 z-30 container mx-auto px-4 z-30 mb-20 max-w-6xl">
        <div class="bg-white rounded-[2rem] shadow-2xl p-8 md:p-12 lg:p-16 border border-gray-100">
            <!-- Intro -->
            <div class="prose prose-lg md:prose-xl text-gray-600 font-light max-w-none text-center mb-16">
                <p>L'Orchestre H₂O est une formation d'harmonie amateur toulousaine fondée en 2011. Notre orchestre réunit des musiciens passionnés autour d'un répertoire varié, allant de la musique classique aux œuvres contemporaines et musiques de films.</p>
            </div>
            
            <div class="flex items-center mb-10 text-center justify-center w-full">
                <h2 class="text-3xl font-bold text-gray-900 text-center">Pourquoi nous rejoindre ?</h2>
            </div>
            
            <!-- Bento Box Features -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-20">
                <div class="bg-gradient-to-br from-gray-50 to-white p-8 md:p-10 rounded-3xl border border-gray-100 shadow-sm hover:shadow-xl transition-shadow duration-500 flex flex-col justify-between border-t-4 border-t-h2o-blue">
                    <div>
                        <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-blue-50 text-h2o-blue mb-6 shadow-inner">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
                            </svg>
                        </div>
                        <h3 class="text-2xl font-bold text-gray-900 mb-4 tracking-tight">Pratiquer la musique à bon niveau</h3>
                        <p class="text-gray-600 font-light leading-relaxed">Développez votre pratique musicale au sein d'une formation complète et ambitieuse, sous la direction de chefs talentueux cherchant l'excellence tout en gardant un esprit amateur engagé.</p>
                    </div>
                </div>
                
                <div class="bg-gradient-to-br from-gray-50 to-white p-8 md:p-10 rounded-3xl border border-gray-100 shadow-sm hover:shadow-xl transition-shadow duration-500 flex flex-col justify-between border-t-4 border-t-pumpkin-500">
                    <div>
                        <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-pumpkin-50 text-pumpkin-500 mb-6 shadow-inner">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                            </svg>
                        </div>
                        <h3 class="text-2xl font-bold text-gray-900 mb-4 tracking-tight">Intégrer une communauté</h3>
                        <p class="text-gray-600 font-light leading-relaxed">Rejoignez un grand groupe de musiciens passionnés et créez des liens durables autour de la musique, des concerts thématiques, et de projets communs enrichissants.</p>
                    </div>
                </div>
            </div>
            
            <!-- Organization Info in a refined grid -->
            <div class="bg-gray-900 rounded-[2rem] p-8 md:p-12 text-white shadow-2xl overflow-hidden relative">
                <div class="absolute top-0 right-0 w-64 h-64 bg-pumpkin-500/10 rounded-full blur-3xl"></div>
                <h2 class="text-3xl font-bold mb-8 relative z-10 text-center tracking-tight">L'Organisation de l'Orchestre</h2>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative z-10">
                    <div class="bg-white/10 backdrop-blur-md p-6 rounded-2xl border border-white/10 text-center hover:-translate-y-1 transition-transform duration-300">
                        <h4 class="text-pumpkin-400 font-bold mb-2 uppercase tracking-wide text-sm">Répétitions</h4>
                        <p class="font-light text-gray-300 leading-relaxed text-sm">Une fois par mois le Dimanche<br/>de 09h00 à 17h00<br/>École de musique d'Aussonne</p>
                    </div>
                    <div class="bg-white/10 backdrop-blur-md p-6 rounded-2xl border border-white/10 text-center hover:-translate-y-1 transition-transform duration-300">
                        <h4 class="text-pumpkin-400 font-bold mb-2 uppercase tracking-wide text-sm">Supplémentaires</h4>
                        <p class="font-light text-gray-300 leading-relaxed text-sm">Un week-end de travail intensif peut être organisé pendant la session en fonction des œuvres.</p>
                    </div>
                    <div class="bg-white/10 backdrop-blur-md p-6 rounded-2xl border border-white/10 text-center hover:-translate-y-1 transition-transform duration-300">
                        <h4 class="text-pumpkin-400 font-bold mb-2 uppercase tracking-wide text-sm">Concerts</h4>
                        <p class="font-light text-gray-300 leading-relaxed text-sm">Environ 3 à 4 concerts par session musicale (deux grandes sessions étalées dans l'année).</p>
                    </div>
                </div>
                <div class="mt-8 text-center text-gray-400 font-light text-sm italic relative z-10">
                    Toutes les dates de concerts et de répétitions sont disponibles très en avance et communiquées à l'ensemble des musiciens sur le planning interne.
                </div>
            </div>
        </div>
    </div>
    
    <!-- Open positions Full Width Dark Background for Contrast -->
    <section class="py-24 bg-gray-50 border-t border-gray-100 relative">
        <div class="container mx-auto px-4 max-w-5xl">
            <div class="text-center mb-16">
                <h2 class="text-4xl font-extrabold text-gray-900 tracking-tight">Postes actuellement ouverts</h2>
                <div class="h-1 w-24 bg-pumpkin-500 mx-auto mt-6 rounded-full"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
                {allRecrutements.items.map(r => {
                    return <div class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col justify-between group transform hover:-translate-y-1">
                        <div>
                            <div class="flex justify-between items-start mb-4 gap-4">
                                <h3 class="text-2xl font-bold text-gray-900 group-hover:text-pumpkin-600 transition-colors">{r.fields.instrument}</h3>
                                <span class="inline-flex flex-shrink-0 items-center px-4 py-1.5 bg-red-100 text-red-800 text-sm font-bold rounded-full whitespace-nowrap shadow-sm border border-red-200">
                                    {r.fields.postesOuverts} {r.fields.postesOuverts > 1 ? 'Postes' : 'Poste'}
                                </span>
                            </div>
                            <p class="text-gray-600 mb-6 font-light leading-relaxed">{r.fields.description}</p>
                        </div>
                        <a href="#application" class="inline-flex items-center text-pumpkin-500 font-bold uppercase tracking-wide text-sm hover:text-pumpkin-600 transition-colors">
                            Postuler
                            <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                            </svg>
                        </a>
                    </div>
                })}
            </div>
            
            <div class="bg-gradient-to-r from-gray-900 to-gray-800 p-8 md:p-10 rounded-2xl shadow-xl text-white flex flex-col md:flex-row items-center justify-between gap-8 border border-gray-700">
                <div class="flex-grow">
                    <h3 class="text-xl font-bold mb-2">Candidature spontanée</h3>
                    <p class="text-gray-300 font-light max-w-2xl">Si votre instrument n'est pas mentionné, nous vous invitons quand même à nous contacter. Nous constituons régulièrement une liste d'attente détaillée pour les postes qui se libèrent à tout moment.</p>
                </div>
                <a href="#application" class="whitespace-nowrap inline-flex items-center justify-center px-8 py-4 font-bold rounded-full text-gray-900 bg-white hover:bg-gray-100 transition-colors shadow-lg">
                    Contactez-nous
                </a>
            </div>
        </div>
    </section>
    
    <!-- Application process -->
    <section id="application" class="py-24 bg-white relative">
        <div class="container mx-auto px-4 max-w-4xl text-center">
            <h2 class="text-4xl font-extrabold text-gray-900 mb-6 tracking-tight">Comment postuler ?</h2>
            <p class="text-xl text-gray-600 font-light mb-16">Le processus d'intégration est rapide et très simple.</p>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10 text-left">
                <div class="bg-gray-50 p-10 rounded-[2rem] border border-gray-100 relative shadow-sm">
                    <div class="absolute -top-6 -left-6 w-16 h-16 bg-white border-4 border-pumpkin-500 rounded-full flex items-center justify-center text-2xl font-black text-pumpkin-500 shadow-xl">1</div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-4 pt-4">Envoyez votre candidature</h3>
                    <p class="text-gray-600 font-light leading-relaxed mb-6">Faites nous parvenir un simple mail ou appelez-nous directement. Présentez votre parcours, votre instrument et vos motivations.</p>
                    <div class="flex flex-col gap-3 font-medium">
                        <a href="mailto:contact@orchestre-h2o.fr" class="inline-flex items-center text-pumpkin-600 hover:text-pumpkin-700 transition-colors">
                            <span class="bg-pumpkin-100 p-2 rounded-full mr-3"><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg></span>
                            contact@orchestre-h2o.fr
                        </a>
                        <a href="tel:0662740728" class="inline-flex items-center text-pumpkin-600 hover:text-pumpkin-700 transition-colors">
                            <span class="bg-pumpkin-100 p-2 rounded-full mr-3"><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg></span>
                            06 62 74 07 28
                        </a>
                    </div>
                </div>
                
                <div class="bg-gray-50 p-10 rounded-[2rem] border border-gray-100 relative shadow-sm">
                    <div class="absolute -top-6 -left-6 w-16 h-16 bg-white border-4 border-h2o-blue rounded-full flex items-center justify-center text-2xl font-black text-h2o-blue shadow-xl">2</div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-4 pt-4">Vous recevez une réponse</h3>
                    <p class="text-gray-600 font-light leading-relaxed">Notre équipe pédagogique analyse votre profil et les besoins des pupitres. Si votre profil correspond bien, nous vous invitons avec plaisir à nous rejoindre en condition réelle lors de la répétition suivante pour faire connaissance !</p>
                </div>
            </div>
        </div>
    </section>
</Layout>