---
import {contentfulClient, concerts} from "../../lib/contentful";
import type {Concert} from "../../lib/contentful";
import {getSeason} from "../../lib/seasons";
import Layout from "../../layouts/Layout.astro";
import { truncateDescription } from "../../lib/string";

export async function getStaticPaths() {
    const entries = await contentfulClient.getEntries<Concert>({
        content_type: "concert",
    });

    const seasons = [...new Set(entries.items.map((entry) => getSeason(new Date(entry.fields.date))))];

    return seasons.map((item) => {
        return (
            {
                params: {slug: item},
                props: {
                    season: item,
                },
            })
    });
}

const {season} = Astro.props;

const concertsBySeason = concerts.filter((item) => getSeason(new Date(item.date)) === season);
---

<Layout title={`Concerts de la saison ${season}`} activeNav="saisons">
    <!-- Hero section with Dark Theme -->
    <div class="relative bg-gray-900 py-24 lg:py-32 overflow-hidden">
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-gradient-to-br from-pumpkin-900/60 via-gray-900 to-gray-900 z-10"></div>
            <div class="absolute bottom-0 left-0 w-[60%] h-[60%] rounded-full bg-h2o-blue/20 blur-[130px] mix-blend-screen"></div>
        </div>
        <div class="container mx-auto px-4 relative z-20 text-center">
            <h1 class="text-5xl md:text-6xl font-extrabold text-white mb-6 tracking-tight drop-shadow-sm">Saison {season}</h1>
            <p class="text-xl md:text-2xl text-gray-300 font-light max-w-2xl mx-auto leading-relaxed">
                Découvrez tous les concerts de notre orchestre pour cette saison musicale.
            </p>
        </div>
    </div>
    
    <div class="bg-gray-50 py-20 relative overflow-hidden">
        <div class="container mx-auto px-4 relative z-10 max-w-7xl">
            {concertsBySeason.length === 0 ? (
                <div class="bg-white rounded-3xl p-12 text-center shadow-sm border border-gray-100 max-w-2xl mx-auto">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-gray-300 mx-auto mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <p class="text-xl text-gray-600 mb-8 font-light">Aucun concert n'est programmé pour cette saison.</p>
                    <a href="/" class="inline-flex font-bold items-center px-8 py-3 bg-gray-900 text-white rounded-full hover:bg-pumpkin-500 transition-colors shadow-lg hover:shadow-pumpkin-500/30">
                        Retour à l'accueil
                    </a>
                </div>
            ) : (
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
                    {concertsBySeason.map((concert) => (
                        <a 
                            href={`/concert/${encodeURI(concert.title.toLowerCase().replace(/\s+/g, '-'))}`}
                            class="group relative bg-white rounded-[2rem] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2 border border-gray-100 flex flex-col h-[500px]"
                        >
                            <!-- Image Background filling the card logically -->
                            <div class="absolute inset-0 z-0 bg-gray-900">
                                {concert.poster ? (
                                    <img 
                                        src={concert.poster}
                                        alt={concert.title}
                                        class="w-full h-full object-cover opacity-[0.85] transition-transform duration-1000 group-hover:scale-105"
                                    />
                                ) : (
                                    <div class="w-full h-full bg-gradient-to-br from-pumpkin-100 to-white"></div>
                                )}
                            </div>
                            
                            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/90 via-gray-900/40 to-transparent z-10 pointer-events-none"></div>
                            
                            <div class="relative z-20 p-8 flex flex-col h-full justify-end">
                                <div class="mb-auto flex justify-between items-start w-full">
                                    <span class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-bold bg-white/90 backdrop-blur-md text-gray-900 shadow-sm">
                                        {new Date(concert.date).toLocaleDateString("fr-FR", {day: 'numeric', month: 'long', year: 'numeric', timeZone: 'Europe/Paris'})}
                                    </span>
                                </div>
                                
                                <div class="bg-white/10 backdrop-blur-md p-6 rounded-2xl border border-white/20 transform group-hover:-translate-y-1 transition-transform duration-500">
                                    <h2 class="text-2xl font-bold text-white mb-3 drop-shadow-sm line-clamp-2">
                                        {concert.title}
                                    </h2>
                                    
                                    {concert.description && (
                                        <div class="text-gray-300 line-clamp-2 font-light text-sm mb-4" set:html={truncateDescription(concert.description)}>
                                        </div>
                                    )}
                                    
                                    <span class="inline-flex items-center text-pumpkin-400 font-bold group-hover:text-pumpkin-300 transition-colors text-sm uppercase tracking-wide">
                                        Explorer
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                        </svg>
                                    </span>
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            )}
        </div>
    </div>
</Layout>