---
import Layout from '../../layouts/Layout.astro';
import {contentfulClient, type Chef, allChef, nextConcerts} from "../../lib/contentful";
import { documentToHtmlString } from "@contentful/rich-text-html-renderer";
import { renderRichText } from "../../lib/richTextRenderer";

export async function getStaticPaths() {
    // Find the current conductor first
    const currentConductorItem = allChef.items.find(chef => chef.fields.courant);
    let currentConductor = null;
    
    if (currentConductorItem) {
        const portraitUrl = currentConductorItem.fields.portrait?.sys?.id 
            ? (await contentfulClient.getAsset(currentConductorItem.fields.portrait.sys.id)).fields.file?.url
            : undefined;
            
        currentConductor = {
            name: currentConductorItem.fields.name,
            resume: documentToHtmlString(currentConductorItem.fields.resume),
            description: renderRichText(currentConductorItem.fields.description),
            portrait: portraitUrl,
            isCurrent: true,
            slug: 'current'
        };
    }

    // Create a path for each chef
    const paths = await Promise.all(allChef.items.map(async (chef) => {
        const portraitUrl = chef.fields.portrait?.sys?.id 
            ? (await contentfulClient.getAsset(chef.fields.portrait.sys.id)).fields.file?.url
            : undefined;
            
        return {
            params: { 
                slug: chef.fields.courant ? 'current' : chef.fields.name.toLowerCase().replace(/\s+/g, '-') 
            },
            props: { 
                chef: {
                    name: chef.fields.name,
                    resume: documentToHtmlString(chef.fields.resume),
                    description: renderRichText(chef.fields.description),
                    portrait: portraitUrl,
                    isCurrent: chef.fields.courant
                },
                currentConductor
            }
        };
    }));
    
    return paths;
}

const { chef, currentConductor } = Astro.props;
---

<Layout title={`${chef.name} - Direction Musicale`} activeNav="direction">
    <!-- Hero Section with Dark Theme -->
    <div class="relative bg-gray-900 py-24 lg:py-32 overflow-hidden">
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-gradient-to-tr from-pumpkin-900/40 via-gray-900 to-gray-900 z-10"></div>
            <div class="absolute top-[20%] -right-[10%] w-[50%] h-[50%] rounded-full bg-pumpkin-600/20 blur-[120px]"></div>
        </div>
        <div class="container mx-auto px-4 relative z-20">
            <div class="max-w-4xl">
                {chef.isCurrent && (
                    <div class="inline-block px-4 py-1.5 bg-pumpkin-500 text-white text-sm font-bold tracking-widest uppercase rounded-full mb-6">
                        Chef Actuel
                    </div>
                )}
                <h1 class="text-5xl md:text-6xl font-extrabold text-white mb-6 tracking-tight drop-shadow-sm">{chef.name}</h1>
                <p class="text-xl md:text-2xl text-gray-300 font-light leading-relaxed max-w-2xl">
                    Direction Musicale de l'Orchestre H₂O
                </p>
            </div>
        </div>
    </div>
    
    <!-- Detailed biography - Split Screen -->
    <section class="py-20 md:py-32 bg-white relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-full overflow-hidden z-0 pointer-events-none">
            <div class="absolute top-[20%] left-[10%] w-[30%] h-[30%] rounded-full bg-blue-50/50 blur-3xl"></div>
        </div>
        
        <div class="container mx-auto px-4 relative z-10">
            <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 lg:gap-24 items-start">
                
                <!-- Fixed Portrait Left Side -->
                <div class="lg:w-1/3 w-full lg:sticky lg:top-32">
                    {chef.portrait ? (
                         <div class="relative group">
                            <div class="absolute -inset-4 bg-pumpkin-100/60 rounded-[2.5rem] transform -rotate-3 group-hover:-rotate-6 transition-transform duration-700"></div>
                            <img 
                                src={chef.portrait} 
                                alt={`${chef.name} - Chef d'orchestre`} 
                                class="relative z-10 w-full rounded-[2rem] shadow-2xl object-cover object-center aspect-[4/5] transform group-hover:scale-[1.02] transition-transform duration-700"
                            />
                        </div>
                    ) : (
                        <div class="w-full rounded-[2rem] bg-gray-100 aspect-[4/5] flex items-center justify-center border-2 border-dashed border-gray-300 shadow-inner">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                        </div>
                    )}
                </div>
                
                <!-- Biography Text Right Side -->
                <div class="lg:w-2/3 w-full prose prose-lg md:prose-xl text-gray-600 prose-h3:text-gray-900 prose-h3:font-bold prose-h3:mt-12 prose-a:text-pumpkin-600 hover:prose-a:text-pumpkin-700 max-w-none leading-relaxed font-light">
                    <h2 class="text-3xl font-bold text-gray-900 mb-8 tracking-tight border-b-2 border-pumpkin-500 pb-4 inline-block">Biographie</h2>
                    <div set:html={chef.description}></div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Related Context Box -->
    <section class="py-20 bg-slate-50 border-t border-gray-100">
        <div class="container mx-auto px-4">
            <div class="max-w-7xl mx-auto">
                <div class="flex items-center mb-12">
                    <h2 class="text-3xl font-bold text-gray-900">
                        {chef.isCurrent ? 'Prochains concerts avec '+chef.name : 'Direction actuelle'}
                    </h2>
                    <div class="ml-6 h-px bg-gray-300 flex-grow"></div>
                </div>
                
                {chef.isCurrent ? (
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        {nextConcerts.slice(0, 3).map((concert) => {
                            const plainText = concert.description.replace(/<[^>]*>/g, '');
                            const shortDescription = plainText.length > 100 ? plainText.substring(0, 100) + '...' : plainText;
                            const concertSlug = concert.title.toLowerCase().replace(/\s+/g, '-');
                            
                            return (
                                <a href={`/concert/${concertSlug}`} class="group bg-white rounded-3xl p-8 shadow-sm hover:shadow-2xl transition-all duration-500 border border-gray-100 transform hover:-translate-y-2 flex flex-col h-full">
                                    <div class="inline-flex items-center px-4 py-1.5 bg-pumpkin-100 text-pumpkin-800 text-xs font-bold uppercase tracking-wider rounded-full mb-6 max-w-max">
                                        {concert.date.toLocaleDateString('fr-FR', {day: 'numeric', month: 'long', year: 'numeric', timeZone: 'Europe/Paris'})}
                                    </div>
                                    <h3 class="text-2xl font-bold text-gray-900 mb-4 group-hover:text-pumpkin-600 transition-colors">{concert.title}</h3>
                                    <p class="text-gray-600 mb-8 font-light flex-grow">{shortDescription}</p>
                                    <div class="text-pumpkin-500 font-bold flex items-center group-hover:text-pumpkin-700 transition-colors">
                                        En savoir plus 
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                        </svg>
                                    </div>
                                </a>
                            );
                        })}
                        {nextConcerts.length === 0 && (
                            <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100 col-span-full text-center">
                                <p class="text-gray-600 text-lg">Aucun concert à venir n'est programmé pour le moment.</p>
                            </div>
                        )}
                    </div>
                ) : (
                    <div class="bg-white rounded-3xl p-8 md:p-12 shadow-sm hover:shadow-xl transition-all duration-500 border border-gray-100 flex flex-col md:flex-row gap-10 items-center group">
                        {currentConductor ? (
                            <>
                                <div class="md:w-1/4 w-full">
                                    {currentConductor.portrait ? (
                                        <img 
                                            src={currentConductor.portrait} 
                                            alt={`${currentConductor.name} - Chef d'orchestre actuel`} 
                                            class="w-full rounded-2xl object-cover aspect-[4/5] shadow-lg group-hover:scale-105 transition-transform duration-500"
                                        />
                                    ) : (
                                        <div class="w-full rounded-2xl bg-gray-100 aspect-[4/5] flex items-center justify-center border border-gray-200">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                            </svg>
                                        </div>
                                    )}
                                </div>
                                <div class="md:w-3/4 w-full">
                                    <div class="inline-flex items-center px-3 py-1 bg-pumpkin-100 text-pumpkin-800 text-xs font-bold tracking-widest uppercase rounded-full mb-4">
                                        Chef Actuel
                                    </div>
                                    <h3 class="text-3xl font-bold text-gray-900 mb-4">{currentConductor.name}</h3>
                                    <p class="text-gray-600 mb-8 text-lg font-light leading-relaxed">
                                        {currentConductor.resume.replace(/<[^>]*>/g, '').substring(0, 300)}...
                                    </p>
                                    <a href="/direction/current" class="inline-flex items-center justify-center px-6 py-3 font-bold rounded-full text-white bg-gray-900 hover:bg-pumpkin-600 transition-colors shadow-lg hover:shadow-pumpkin-600/30">
                                        Voir le profil
                                        <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                        </svg>
                                    </a>
                                </div>
                            </>
                        ) : (
                            <div class="w-full text-center py-8">
                                <p class="text-gray-600 text-lg">Aucun chef d'orchestre actuel n'est désigné pour le moment.</p>
                            </div>
                        )}
                    </div>
                )}
            </div>
        </div>
    </section>
</Layout>
