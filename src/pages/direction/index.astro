---
import Layout from '../../layouts/Layout.astro';
import {contentfulClient, type Chef, allChef} from "../../lib/contentful";
import { documentToHtmlString } from "@contentful/rich-text-html-renderer";


// Process the conductors data and sort them (current conductor first, then alphabetically)
const conductors = await Promise.all(allChef.items.map(async (conductor) => {
    const portraitUrl = conductor.fields.portrait?.sys?.id 
        ? (await contentfulClient.getAsset(conductor.fields.portrait.sys.id)).fields.file?.url
        : undefined;
        
    return {
        name: conductor.fields.name,
        resume: documentToHtmlString(conductor.fields.resume),
        portrait: portraitUrl,
        isCurrent: conductor.fields.courant,
        slug: conductor.fields.courant ? 'current' : conductor.fields.name.toLowerCase().replace(/\s+/g, '-')
    };
}));

// Sort conductors: current first, then alphabetically by name
const sortedConductors = conductors.sort((a, b) => {
    if (a.isCurrent && !b.isCurrent) return -1;
    if (!a.isCurrent && b.isCurrent) return 1;
    return a.name.localeCompare(b.name);
});

// Get the current conductor
const currentConductor = sortedConductors.find(conductor => conductor.isCurrent);
---

<Layout title="Direction Musicale" activeNav="direction">
    <!-- Hero section -->
    <div class="relative bg-gray-900 py-24 lg:py-32 overflow-hidden">
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-gradient-to-tr from-pumpkin-900/40 via-gray-900 to-gray-900 z-10"></div>
            <div class="absolute -top-[30%] -right-[10%] w-[50%] h-[50%] rounded-full bg-pumpkin-600/20 blur-[120px]"></div>
        </div>
        <div class="container mx-auto px-4 relative z-20">
            <div class="max-w-4xl">
                <h1 class="text-5xl md:text-6xl font-extrabold text-white mb-6 tracking-tight drop-shadow-sm">Direction Musicale</h1>
                <p class="text-xl md:text-2xl text-gray-300 font-light leading-relaxed max-w-2xl">Découvrez les chefs d'orchestre qui, par leur exigence et leur passion, ont façonné l'identité musicale de notre ensemble.</p>
            </div>
        </div>
    </div>
    
    <!-- Current Conductor Section (Featured) -->
    {currentConductor && (
        <section class="py-10 md:py-20 bg-slate-50 relative overflow-hidden">
            <div class="container mx-auto px-4 relative z-10">
                <div class="max-w-7xl mx-auto">
                    <!-- Split layout for current conductor -->
                    <div class="bg-white rounded-[2.5rem] p-8 md:p-12 lg:p-16 shadow-[0_10px_40px_-15px_rgba(0,0,0,0.05)] border border-gray-100 flex flex-col lg:flex-row gap-12 lg:gap-20 items-center">
                        <div class="lg:w-5/12 w-full lg:order-last">
                            {currentConductor.portrait ? (
                                <div class="relative group">
                                    <div class="absolute -inset-4 bg-pumpkin-200/50 rounded-[2.5rem] transform rotate-3 group-hover:rotate-6 transition-transform duration-700"></div>
                                    <img 
                                        src={currentConductor.portrait} 
                                        alt={`${currentConductor.name} - Chef d'orchestre actuel`} 
                                        class="relative z-10 w-full rounded-[2rem] shadow-2xl object-cover object-top aspect-[4/5] transform group-hover:scale-[1.02] transition-transform duration-700"
                                    />
                                </div>
                            ) : (
                                <div class="w-full rounded-[2rem] bg-gray-100 aspect-[4/5] flex items-center justify-center border-2 border-dashed border-gray-300">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                    </svg>
                                </div>
                            )}
                        </div>
                        <div class="lg:w-7/12 w-full">
                            <div class="inline-flex items-center px-4 py-1.5 bg-pumpkin-100 text-pumpkin-800 text-sm font-bold uppercase tracking-widest rounded-full mb-8">
                                Chef Actuel
                            </div>
                            <h3 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-8 tracking-tight">{currentConductor.name}</h3>
                            <div class="prose prose-lg md:prose-xl text-gray-600 mb-10 leading-relaxed font-light line-clamp-6" set:html={currentConductor.resume}></div>
                            <a href={`/direction/${currentConductor.slug}`} class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-full text-white bg-gray-900 hover:bg-pumpkin-600 transition-colors duration-300 shadow-lg shadow-gray-900/20 hover:shadow-pumpkin-600/30">
                                Lire la biographie
                                <svg xmlns="http://www.w3.org/2000/svg" class="ml-3 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    )}
    
    <!-- Previous Conductors Section -->
    <section class="py-10 md:py-20 bg-white">
        <div class="container mx-auto px-4">
            <div class="max-w-7xl mx-auto">
                <div class="flex flex-col items-center mb-16">
                    <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4 tracking-tight">Nos Anciens Chefs</h2>
                    <div class="w-24 h-1 bg-pumpkin-500 rounded-full"></div>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
                    {sortedConductors.filter(conductor => !conductor.isCurrent).map((conductor) => (
                        <div class="group bg-slate-50 rounded-3xl overflow-hidden hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 border border-gray-100 flex flex-col h-full">
                            <div class="aspect-[4/3] relative overflow-hidden">
                                {conductor.portrait ? (
                                    <img 
                                        src={conductor.portrait} 
                                        alt={`${conductor.name} - Chef d'orchestre`} 
                                        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                                    />
                                ) : (
                                    <div class="w-full h-full bg-gray-200 flex items-center justify-center">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                        </svg>
                                    </div>
                                )}
                                <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                            </div>
                            <div class="p-8 flex-grow flex flex-col">
                                <h3 class="text-2xl font-bold text-gray-900 mb-4 group-hover:text-pumpkin-600 transition-colors">{conductor.name}</h3>
                                <div class="prose prose-sm text-gray-600 line-clamp-3 mb-6 font-light">
                                    <div set:html={conductor.resume}></div>
                                </div>
                                <div class="mt-auto pt-4">
                                    <a href={`/direction/${conductor.slug}`} class="inline-flex items-center text-pumpkin-600 font-bold hover:text-pumpkin-700 transition-colors">
                                        Découvrir
                                        <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                        </svg>
                                    </a>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>
</Layout>