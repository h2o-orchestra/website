---
import Layout from '../layouts/Layout.astro';
import {allChef, concerts, seasons, contentfulClient, allOrchestre, nextConcerts} from "../lib/contentful";
import {getSeason} from "../lib/seasons";
import Welcome from '../components/Welcome.astro';
import CurrentConductor from "../components/CurrentConductor.astro";
import NextConcert from "../components/NextConcert.astro";
import Orchestra from "../components/Orchestra.astro";
import {documentToHtmlString} from "@contentful/rich-text-html-renderer";




// Get the current conductor
const currentConductor = (await Promise.all(allChef.items.filter(chef => chef.fields.courant).map(async chef => ({
    name: chef.fields.name,
    resume: documentToHtmlString(chef.fields.resume),
    portrait: (await contentfulClient.getAsset(chef.fields.portrait.sys.id)).fields.file?.url
}))))[0];

console.log("number of next concerts:", nextConcerts.length);

// Prepare next concert data or use fallback if none
const nextConcert = nextConcerts.length > 0 ? nextConcerts[0] : {
    title: null,
    description: null,
    date: null,
    price: -1,
    poster: null,
};

console.log("Next concert data:", nextConcert);


// Orchestra information
const orchestraInfo = {
    title: allOrchestre.items[0].fields.title,
    description: documentToHtmlString(allOrchestre.items[0].fields.resume)
};
---

<Layout title="Accueil">
    <!-- Welcome banner -->
    <Welcome currentSeason={seasons[0]} />
    
    <!-- Main content with bento box layout -->
    <section class="py-16 md:py-24 bg-slate-50 relative overflow-hidden">
        <!-- Background subtle shapes -->
        <div class="absolute top-0 left-0 w-full h-full overflow-hidden z-0 pointer-events-none">
            <div class="absolute -top-[20%] -right-[10%] w-[50%] h-[50%] rounded-full bg-pumpkin-100/40 blur-3xl"></div>
            <div class="absolute top-[40%] -left-[10%] w-[40%] h-[40%] rounded-full bg-blue-100/40 blur-3xl"></div>
        </div>

        <div class="container mx-auto px-4 relative z-10">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-gray-900 to-gray-600 mb-4 tracking-tight">Découvrez notre univers</h2>
                <p class="text-lg text-gray-500 max-w-2xl mx-auto">Vivez la magie de la musique orchestrale à travers nos concerts, rencontrez notre chef et explorez l'histoire de notre ensemble.</p>
            </div>
            
            <!-- Bento box grid layout -->
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 auto-rows-[minmax(240px,auto)]">
                <!-- Next concert (Large featured block) -->
                <div class="md:col-span-12 lg:col-span-12 group">
                    <NextConcert 
                        title={nextConcert.title}
                        description={nextConcert.description}
                        date={nextConcert.date}
                        price={nextConcert.price}
                        poster={nextConcert.poster}
                        currentSeason={seasons[0]}
                    />
                </div>
                
                <!-- Conductor info (Tall block) -->
                <div class="md:col-span-6 lg:col-span-5 group h-full">
                    <CurrentConductor 
                        name={currentConductor.name} 
                        resume={currentConductor.resume} 
                        portrait={currentConductor.portrait} 
                    />
                </div>
                
                <!-- Orchestra info (Wide text block) -->
                <div class="md:col-span-6 lg:col-span-7 group">
                    <Orchestra 
                        title={orchestraInfo.title}
                        description={orchestraInfo.description}
                    />
                </div>
            </div>
        </div>
    </section>
    
    <!-- Seasons section -->
    <section class="py-16 md:py-24 bg-white">
        <div class="container mx-auto px-4">
            <h2 class="text-3xl md:text-4xl font-bold text-center text-gray-900 mb-6 tracking-tight">Archives & Saisons</h2>
            <p class="text-lg text-center text-gray-500 mb-12 max-w-3xl mx-auto">
                Explorez notre riche programmation musicale passée et présente.
            </p>
            
            <div class="flex flex-wrap justify-center gap-4">
                {seasons.slice(0, 4).map(season => (
                    <a 
                        href={`/saison/${season}`}
                        class="inline-flex items-center px-8 py-4 bg-white border border-gray-200 rounded-full text-gray-700 hover:border-pumpkin-400 hover:text-pumpkin-600 hover:shadow-md transition-all duration-300 font-medium"
                    >
                        Saison {season}
                    </a>
                ))}
            </div>
        </div>
    </section>
    
    <!-- Join us CTA section -->
    <section class="relative py-20 md:py-32 overflow-hidden bg-gray-900 text-white">
        <!-- Parallax/Gradient Background -->
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-gradient-to-tr from-pumpkin-600/90 to-gray-900/90 z-10"></div>
            <div class="absolute inset-0 bg-[url('/hero-bg-placeholder.jpg')] bg-cover bg-center mix-blend-overlay"></div>
        </div>
        <div class="container mx-auto px-4 text-center relative z-20">
            <h2 class="text-4xl md:text-5xl font-bold mb-6 text-white drop-shadow-sm">Rejoignez l'Orchestre H₂O</h2>
            <p class="text-xl mb-10 max-w-2xl mx-auto text-gray-200 font-light">
                Vous êtes musicien et passionné par la musique orchestrale ? 
                Découvrez nos opportunités musicales et intégrez notre harmonie !
            </p>
            <a 
                href="/recrutement" 
                class="inline-block px-10 py-5 bg-white text-pumpkin-700 font-bold rounded-full hover:bg-gray-100 hover:scale-105 hover:shadow-xl transition-all duration-300 ring-4 ring-white/20"
            >
                Comment nous rejoindre
            </a>
        </div>
    </section>
</Layout>
